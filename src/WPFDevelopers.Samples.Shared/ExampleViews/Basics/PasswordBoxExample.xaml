<UserControl x:Class="WPFDevelopers.Samples.ExampleViews.Basics.PasswordBoxExample"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:WPFDevelopers.Samples.Controls"
    xmlns:wd="https://github.com/WPFDevelopersOrg/WPFDevelopers"
    Background="{DynamicResource WD.BackgroundBrush}">
    <controls:CodeViewer Header="PasswordBox">
        <StackPanel Margin="20,10">
            <TextBlock Margin="0,20,0,0" FontSize="20" Text="PasswordBox" />
            <UniformGrid Margin="0,10" Rows="1">
                <PasswordBox wd:ElementHelper.CornerRadius="3" />
                <PasswordBox
                    Margin="10,0"
                    wd:ElementHelper.IsClear="True"
                    wd:ElementHelper.Watermark="PasswordBox" />
                <PasswordBox IsEnabled="False" />
                <PasswordBox
                    x:Name="myPasswordBox"
                    Margin="10,0"
                    wd:ElementHelper.Watermark="PasswordBox"
                    wd:PasswordBoxHelper.IsMonitoring="True" />
            </UniformGrid>
        </StackPanel>
        <controls:CodeViewer.SourceCodes>
            <controls:SourceCodeModel CodeSource="/WPFDevelopers.SamplesCode;component/ExampleViews/Basics/PasswordBoxExample.xaml" CodeType="Xaml" />
        </controls:CodeViewer.SourceCodes>
    </controls:CodeViewer>
</UserControl>
