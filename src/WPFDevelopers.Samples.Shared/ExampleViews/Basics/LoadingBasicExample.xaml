<UserControl
    x:Class="WPFDevelopers.Samples.ExampleViews.Basics.LoadingBasicExample"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:WPFDevelopers.Samples.Controls"
    xmlns:wd="https://github.com/WPFDevelopersOrg/WPFDevelopers"
    x:Name="MyBasicLoading"
    Background="{DynamicResource WD.BackgroundBrush}">
    <controls:CodeViewer Header="Loading">
        <StackPanel Margin="20,10">
            <TextBlock Margin="0,20,0,0" FontSize="20" Text="Loading" />
            <UniformGrid Height="38" Margin="0,10" Rows="1">
                <Button wd:ElementHelper.CornerRadius="3" Click="Loading_Click" Content="Loading"
                        Style="{DynamicResource WD.PrimaryButton}" />
                <Button Name="btnLoadingTask" Margin="10,0" wd:ElementHelper.CornerRadius="3"
                        Click="LoadingTask_Click" Content="LoadingTask"
                        Style="{DynamicResource WD.SuccessPrimaryButton}" />
                <Button Name="btnLoading" wd:Loading.LoadingType="Normal" Click="BtnLoading_Click"
                        Content="AddLoading" Style="{DynamicResource WD.WarningPrimaryButton}" />
                <Button Name="btnOffTask" Margin="10,0" Click="BtnOffTask_Click" Content="Off Task"
                        Style="{DynamicResource WD.DangerPrimaryButton}" />
                <Button wd:Badge.IsShow="True" wd:Loading.IsShow="True" wd:Loading.LoadingType="Normal"
                        Content="NormalLoading" Style="{DynamicResource WD.PrimaryButton}" />
            </UniformGrid>
        </StackPanel>
        <controls:CodeViewer.SourceCodes>
            <controls:SourceCodeModel CodeSource="/WPFDevelopers.SamplesCode;component/ExampleViews/Basics/LoadingBasicExample.xaml" CodeType="Xaml" />
            <controls:SourceCodeModel CodeSource="/WPFDevelopers.SamplesCode;component/ExampleViews/Basics/LoadingBasicExample.xaml.cs" CodeType="CSharp" />
        </controls:CodeViewer.SourceCodes>
    </controls:CodeViewer>
</UserControl>
