<UserControl x:Class="WPFDevelopers.Samples.ExampleViews.Basics.RadioButtonExample"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:WPFDevelopers.Samples.Controls"
    Background="{DynamicResource WD.BackgroundBrush}">
    <controls:CodeViewer Header="RadioButton">
        <StackPanel Margin="20,10">
            <TextBlock Margin="0,20,0,0" FontSize="20" Text="RadioButton" />
            <WrapPanel Margin="0,10">
                <RadioButton Content="Option A" />
                <RadioButton Margin="10,0" Content="Option B" IsChecked="True" />
                <RadioButton Content="Option C" IsEnabled="False" />
            </WrapPanel>
        </StackPanel>
        <controls:CodeViewer.SourceCodes>
            <controls:SourceCodeModel CodeSource="/WPFDevelopers.SamplesCode;component/ExampleViews/Basics/RadioButtonExample.xaml" CodeType="Xaml" />
        </controls:CodeViewer.SourceCodes>
    </controls:CodeViewer>
</UserControl>
