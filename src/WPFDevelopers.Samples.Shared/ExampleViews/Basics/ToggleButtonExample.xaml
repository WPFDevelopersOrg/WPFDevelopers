<UserControl x:Class="WPFDevelopers.Samples.ExampleViews.Basics.ToggleButtonExample"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:WPFDevelopers.Samples.Controls"
    Background="{DynamicResource WD.BackgroundBrush}">
    <controls:CodeViewer Header="ToggleButton">
        <StackPanel Margin="20,10">
            <TextBlock Margin="0,20,0,0" FontSize="20" Text="ToggleButton" />
            <WrapPanel Margin="0,10">
                <ToggleButton Content="IsOpen" />
                <ToggleButton
                    Margin="10,0"
                    Content="False"
                    IsEnabled="False" />
                <ToggleButton
                    Padding="10,0"
                    Content="启用"
                    IsChecked="True" />
            </WrapPanel>
        </StackPanel>
        <controls:CodeViewer.SourceCodes>
            <controls:SourceCodeModel CodeSource="/WPFDevelopers.SamplesCode;component/ExampleViews/Basics/ToggleButtonExample.xaml" CodeType="Xaml" />
        </controls:CodeViewer.SourceCodes>
    </controls:CodeViewer>
</UserControl>
