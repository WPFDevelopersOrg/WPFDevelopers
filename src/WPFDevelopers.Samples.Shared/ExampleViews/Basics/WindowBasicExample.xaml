<UserControl
    x:Class="WPFDevelopers.Samples.ExampleViews.Basics.WindowBasicExample"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:WPFDevelopers.Samples.Controls"
    xmlns:wd="https://github.com/WPFDevelopersOrg/WPFDevelopers"
    Background="{DynamicResource WD.BackgroundBrush}">
    <controls:CodeViewer Header="Window">
        <StackPanel Margin="20,10">
            <TextBlock Margin="0,20,0,0" FontSize="20" Text="Window" />
            <UniformGrid Height="38" Margin="0,10" Rows="1">
                <Button
                    wd:ElementHelper.CornerRadius="3"
                    Click="Button_Click"
                    Content="ToolWindow"
                    Style="{DynamicResource WD.PrimaryButton}" />
                <Button
                    Margin="10,0"
                    Click="ButtonNone_Click"
                    Content="NoneTitleBarWindow"
                    Style="{DynamicResource WD.DangerPrimaryButton}" />
            </UniformGrid>
        </StackPanel>
        <controls:CodeViewer.SourceCodes>
            <controls:SourceCodeModel CodeSource="/WPFDevelopers.SamplesCode;component/ExampleViews/Basics/WindowBasicExample.xaml" CodeType="Xaml" />
        </controls:CodeViewer.SourceCodes>
    </controls:CodeViewer>
</UserControl>
