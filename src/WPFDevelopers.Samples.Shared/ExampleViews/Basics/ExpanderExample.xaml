<UserControl
    x:Class="WPFDevelopers.Samples.ExampleViews.Basics.ExpanderExample"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:WPFDevelopers.Samples.Controls"
    xmlns:wd="https://github.com/WPFDevelopersOrg/WPFDevelopers"
    Background="{DynamicResource WD.BackgroundBrush}">
    <controls:CodeViewer Header="Expander">
        <wd:WDScrollViewer>
            <StackPanel Margin="20,10">
                <TextBlock
                    Margin="0,20,0,0"
                    FontSize="20"
                    Text="Expander" />
                <UniformGrid Margin="0,10" Columns="2">
                    <Expander wd:ElementHelper.CornerRadius="3" Header="Expander1">
                        <Rectangle
                            Width="400"
                            Height="300"
                            Fill="{DynamicResource WD.DangerBrush}" />
                    </Expander>
                    <Expander
                        Margin="10,0"
                        ExpandDirection="Up"
                        FlowDirection="RightToLeft"
                        Header="Expander1"
                        IsExpanded="True">
                        <Rectangle
                            Width="400"
                            Height="300"
                            Fill="{DynamicResource WD.LightBrush}" />
                    </Expander>
                    <Expander Margin="0,10" ExpandDirection="Right">
                        <Expander.Header>
                            <TextBlock Text="Expander1">
                                <TextBlock.LayoutTransform>
                                    <RotateTransform Angle="90" />
                                </TextBlock.LayoutTransform>
                            </TextBlock>
                        </Expander.Header>
                        <Rectangle
                            Width="400"
                            Height="300"
                            Fill="{DynamicResource WD.CircularSingularSolidColorBrush}" />
                    </Expander>
                    <Expander
                        Margin="10"
                        ExpandDirection="Left"
                        IsExpanded="True">
                        <Expander.Header>
                            <TextBlock Text="Expander1">
                                <TextBlock.LayoutTransform>
                                    <RotateTransform Angle="90" />
                                </TextBlock.LayoutTransform>
                            </TextBlock>
                        </Expander.Header>
                        <Rectangle
                            Width="400"
                            Height="300"
                            Fill="{DynamicResource WD.PrimaryBrush}" />
                    </Expander>
                </UniformGrid>
            </StackPanel>
        </wd:WDScrollViewer>
        <controls:CodeViewer.SourceCodes>
            <controls:SourceCodeModel CodeSource="/WPFDevelopers.SamplesCode;component/ExampleViews/Basics/ExpanderExample.xaml" CodeType="Xaml" />
        </controls:CodeViewer.SourceCodes>
    </controls:CodeViewer>
</UserControl>
