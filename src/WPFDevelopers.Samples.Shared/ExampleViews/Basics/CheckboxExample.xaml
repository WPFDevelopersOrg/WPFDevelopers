<UserControl x:Class="WPFDevelopers.Samples.ExampleViews.Basics.CheckboxExample"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:WPFDevelopers.Samples.Controls"
    xmlns:wd="https://github.com/WPFDevelopersOrg/WPFDevelopers"
    Background="{DynamicResource WD.BackgroundBrush}">
    <controls:CodeViewer Header="Checkbox">
        <StackPanel Margin="20,10">
            <TextBlock Margin="0,20,0,0" FontSize="20" Text="Checkbox" />
            <WrapPanel Margin="0,10">
                <CheckBox Content="Option A" />
                <CheckBox Margin="10,0" wd:ElementHelper.CornerRadius="3" Content="Option B" IsChecked="True" />
                <CheckBox Content="Option C" IsChecked="{x:Null}" />
                <CheckBox Margin="10,0" Content="Option D" IsEnabled="False" />
            </WrapPanel>
        </StackPanel>
        <controls:CodeViewer.SourceCodes>
            <controls:SourceCodeModel CodeSource="/WPFDevelopers.SamplesCode;component/ExampleViews/Basics/CheckboxExample.xaml" CodeType="Xaml" />
        </controls:CodeViewer.SourceCodes>
    </controls:CodeViewer>
</UserControl>
