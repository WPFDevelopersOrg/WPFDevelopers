<UserControl
    x:Class="WPFDevelopers.Samples.ExampleViews.SegmentedExample"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:WPFDevelopers.Samples.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:wd="https://github.com/WPFDevelopersOrg/WPFDevelopers"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <controls:CodeViewer Header="{Binding NavigateMenuItem.Name}">
        <StackPanel
            Margin="20"
            HorizontalAlignment="Center"
            VerticalAlignment="Top"
            Orientation="Horizontal">
            <StackPanel wd:PanelHelper.Spacing="10" Orientation="Vertical">
                <TextBlock
                    FontSize="14"
                    FontWeight="Bold"
                    Text="横向 (Horizontal)" />
                <TextBlock
                    Margin="0,10,0,0"
                    FontSize="12"
                    Foreground="Gray"
                    Text="XAML 模式：" />

                <wd:Segmented
                    x:Name="HorizontalXAMLSegmented"
                    Width="300"
                    ItemClick="Segmented_ItemClick"
                    SelectedIndex="0">
                    <wd:SegmentedItem Content="Large" />
                    <wd:SegmentedItem Content="Medium" />
                    <wd:SegmentedItem Content="Small" />
                </wd:Segmented>


                <wd:Segmented Width="300" SelectedIndex="0">
                    <wd:SegmentedItem>
                        <StackPanel>
                            <wd:PathIcon Kind="Home" />
                            <TextBlock Text="Home" />
                        </StackPanel>
                    </wd:SegmentedItem>
                    <wd:SegmentedItem>
                        <StackPanel>
                            <wd:PathIcon Kind="Friend" />
                            <TextBlock Text="Friend" />
                        </StackPanel>
                    </wd:SegmentedItem>
                    <wd:SegmentedItem>
                        <StackPanel>
                            <wd:PathIcon Kind="Star" />
                            <TextBlock Text="Star" />
                        </StackPanel>
                    </wd:SegmentedItem>
                </wd:Segmented>

                <TextBlock>
                    <Run Text="选中索引：" />
                </TextBlock>

                <TextBlock
                    Margin="0,20,0,0"
                    FontSize="12"
                    Text="MVVM 模式：" />

                <wd:Segmented
                    x:Name="HorizontalMVVMSegmented"
                    Width="300"
                    wd:ElementHelper.CornerRadius="15"
                    DisplayMemberPath="Name"
                    ItemClickCommand="{Binding ItemClickCommand}"
                    ItemsSource="{Binding Options}"
                    SelectedIndex="{Binding SelectedOptionIndex, Mode=TwoWay}" />
            </StackPanel>

            <Rectangle
                Width="1"
                Margin="40,0"
                Fill="LightGray" />

            <StackPanel wd:PanelHelper.Spacing="10" Orientation="Vertical">
                <TextBlock
                    FontSize="14"
                    FontWeight="Bold"
                    Text="竖向 (Vertical)" />

                <wd:Segmented
                    x:Name="VerticalXAMLSegmented"
                    Height="200"
                    Margin="0,10,0,0"
                    ItemClick="Segmented_ItemClick"
                    Orientation="Vertical"
                    SelectedIndex="0">
                    <wd:SegmentedItem Content="Option A" />
                    <wd:SegmentedItem Content="Option B" />
                    <wd:SegmentedItem Content="Option C" />
                    <wd:SegmentedItem Content="Option D" />
                </wd:Segmented>
            </StackPanel>
        </StackPanel>

        <controls:CodeViewer.SourceCodes>
            <controls:SourceCodeModel CodeSource="/WPFDevelopers.SamplesCode;component/ExampleViews/SegmentedExample.xaml" CodeType="Xaml" />
            <controls:SourceCodeModel CodeSource="/WPFDevelopers.SamplesCode;component/ExampleViews/SegmentedExample.xaml.cs" CodeType="CSharp" />
        </controls:CodeViewer.SourceCodes>
    </controls:CodeViewer>
</UserControl>
