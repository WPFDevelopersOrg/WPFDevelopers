<UserControl
    x:Class="WPFDevelopers.Sample.ExampleViews.GrayscaleEffectExample"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:WPFDevelopers.Samples.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:WPFDevelopers.Samples.ExampleViews"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:wd="https://github.com/WPFDevelopersOrg/WPFDevelopers"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <controls:CodeViewer Header="{Binding NavigateMenuItem.Name}">
        <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
            <Slider
                x:Name="factorSlider"
                Width="300"
                Margin="0,10"
                HorizontalAlignment="Left"
                Maximum="1"
                Minimum="0"
                ValueChanged="FactorSlider_ValueChanged"
                Value="0" />
            <TextBlock
                Margin="0,5"
                HorizontalAlignment="Left"
                FontSize="14">
                <Run>灰度强度：</Run>
                <Run x:Name="factorText" Text="0" />
            </TextBlock>
        </StackPanel>
        <controls:CodeViewer.SourceCodes>
            <controls:SourceCodeModel CodeSource="/WPFDevelopers.SamplesCode;component/ExampleViews/GrayscaleEffectExample.xaml" CodeType="Xaml" />
            <controls:SourceCodeModel CodeSource="/WPFDevelopers.SamplesCode;component/ExampleViews/GrayscaleEffectExample.xaml.cs" CodeType="CSharp" />
        </controls:CodeViewer.SourceCodes>
    </controls:CodeViewer>
</UserControl>
