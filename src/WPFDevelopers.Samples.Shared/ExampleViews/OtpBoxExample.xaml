<UserControl
    x:Class="WPFDevelopers.Sample.ExampleViews.OtpBoxExample"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:WPFDevelopers.Samples.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:WPFDevelopers.Samples.ExampleViews"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:wd="https://github.com/WPFDevelopersOrg/WPFDevelopers"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <controls:CodeViewer Header="{Binding NavigateMenuItem.Name}">
        <TabControl TabStripPlacement="Bottom">
            <TabItem Header="Event">
                <wd:OtpBox
                    x:Name="myOtpBox"
                    Width="200"
                    wd:ElementHelper.CornerRadius="5"
                    Completed="OtpBoxCompleted" />
            </TabItem>
            <TabItem Header="Command">
                <wd:OtpBox
                    x:Name="myOtpBox2"
                    Width="200"
                    CompletedCommand="{Binding CompletedCommand, RelativeSource={RelativeSource AncestorType=UserControl}}" />
            </TabItem>
        </TabControl>
        <controls:CodeViewer.SourceCodes>
            <controls:SourceCodeModel CodeSource="/WPFDevelopers.SamplesCode;component/ExampleViews/OtpBoxExample.xaml" CodeType="Xaml" />
            <controls:SourceCodeModel CodeSource="/WPFDevelopers.SamplesCode;component/ExampleViews/OtpBoxExample.xaml.cs" CodeType="CSharp" />
        </controls:CodeViewer.SourceCodes>
    </controls:CodeViewer>
</UserControl>
