<UserControl
    x:Class="WPFDevelopers.Samples.ExampleViews.CircleMenuExample"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:WPFDevelopers.Samples.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:WPFDevelopers.Samples.ExampleViews"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:wd="https://github.com/WPFDevelopersOrg/WPFDevelopers"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <controls:CodeViewer Header="{Binding NavigateMenuItem.Name}">
        <TabControl ClipToBounds="False">
            <TabItem Header="XAML">
                <wd:CircleMenu
                    Width="100"
                    Height="100"
                    ItemClick="CircleMenu_ItemClick">
                    <wd:CircleMenuItem Tag="Home">
                        <wd:PathIcon Kind="Home" />
                    </wd:CircleMenuItem>
                    <wd:CircleMenuItem Tag="Date">
                        <wd:PathIcon Kind="Date" />
                    </wd:CircleMenuItem>
                    <wd:CircleMenuItem Tag="Copy">
                        <wd:PathIcon Kind="Copy" />
                    </wd:CircleMenuItem>
                    <wd:CircleMenuItem Tag="Undo">
                        <wd:PathIcon Kind="Undo" />
                    </wd:CircleMenuItem>
                </wd:CircleMenu>
            </TabItem>
            <TabItem Header="MVVM">
                <wd:CircleMenu
                    Background="DeepPink"
                    DisplayMemberPath="Icon"
                    ItemClickCommand="{Binding ItemClickCommand}"
                    ItemsSource="{Binding MenuItems}"
                    SectorBackground="Pink"
                    SectorDualBackground="HotPink"
                    SelectedBackground="DeepPink" />
            </TabItem>
        </TabControl>
        <controls:CodeViewer.SourceCodes>
            <controls:SourceCodeModel CodeSource="/WPFDevelopers.SamplesCode;component/ExampleViews/CircleMenuExample.xaml" CodeType="Xaml" />
            <controls:SourceCodeModel CodeSource="/WPFDevelopers.SamplesCode;component/ExampleViews/CircleMenuExample.xaml.cs" CodeType="CSharp" />
        </controls:CodeViewer.SourceCodes>
    </controls:CodeViewer>
</UserControl>
