<UserControl
    x:Class="WPFDevelopers.Samples.ExampleViews.NotifyIconExample"
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:WPFDevelopers.Samples.Controls"
    xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
    xmlns:local="clr-namespace:WPFDevelopers.Samples.ExampleViews"
    xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
    xmlns:wd="https://github.com/WPFDevelopersOrg/WPFDevelopers"
    d:DesignHeight="450"
    d:DesignWidth="800"
    mc:Ignorable="d">
    <controls:CodeViewer Header="{Binding NavigateMenuItem.Name}">
        <TabControl Grid.Row="1" Grid.ColumnSpan="2">
            <TabItem Header="基础用法">
                <ScrollViewer>
                    <StackPanel Margin="10" wd:PanelHelper.Spacing="15">
                        <GroupBox Header="声明托盘图标">
                            <StackPanel wd:PanelHelper.Spacing="8">
                                <TextBlock Text="在 XAML 中声明 wd:NotifyIcon 即可创建系统托盘图标：" TextWrapping="Wrap" />
                                <Border Background="{DynamicResource WD.BackgroundBrush}" Padding="8" CornerRadius="4">
                                    <TextBlock FontFamily="Consolas" TextWrapping="Wrap">
                                    &lt;wd:NotifyIcon x:Name="NotifyIcon1" Title="WPF开发者" Icon="pack://application:,,,/WPFDevelopers.Samples;component/WPFDevelopers.ico"/&gt;
                                    </TextBlock>
                                </Border>
                                <TextBlock Text="只需设置 Title（工具提示文本）和 Icon（托盘图标图片）即可显示托盘图标。" TextWrapping="Wrap" Foreground="{DynamicResource WD.TextSecondaryBrush}" />
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="右键菜单 (ContextMenu)">
                            <StackPanel wd:PanelHelper.Spacing="8">
                                <TextBlock Text="通过 ContextMenu 属性添加标准右键菜单：" TextWrapping="Wrap" />
                                <Border Background="{DynamicResource WD.BackgroundBrush}" Padding="8" CornerRadius="4">
                                    <TextBlock FontFamily="Consolas" FontSize="11" TextWrapping="Wrap">
                                    &lt;wd:NotifyIcon x:Name="NotifyIcon2" Title="WPF开发者"&gt;&#10;    &lt;wd:NotifyIcon.ContextMenu&gt;&#10;        &lt;ContextMenu&gt;&#10;            &lt;MenuItem Header="关于" Click="About_Click"/&gt;&#10;            &lt;MenuItem Header="退出" Click="Quit_Click"/&gt;&#10;        &lt;/ContextMenu&gt;&#10;    &lt;/wd:NotifyIcon.ContextMenu&gt;&#10;&lt;/wd:NotifyIcon&gt;
                                    </TextBlock>
                                </Border>
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="自定义右键面板 (ContextContent)">
                            <StackPanel wd:PanelHelper.Spacing="8">
                                <TextBlock Text="ContextContent 允许在右键弹出自定义 UI（使用 Popup），支持任意控件：" TextWrapping="Wrap" />
                                <wd:NotifyIcon x:Name="NotifyIconCC" Title="WPF开发者 - ContextContent 演示">
                                    <wd:NotifyIcon.ContextContent>
                                        <Border Background="{DynamicResource WD.BackgroundBrush}" BorderBrush="{DynamicResource WD.BorderBrush}" BorderThickness="1" CornerRadius="8" Padding="0">
                                            <StackPanel Width="180">
                                                <Border Background="#4CAF50" Padding="12,8" CornerRadius="8,8,0,0">
                                                    <TextBlock Text="WPFDevelopers" Foreground="White" FontWeight="Bold"/>
                                                </Border>
                                                <Button Content="发送托盘消息" Margin="8,8,8,4" Click="ContextContent_Send_Click" Style="{StaticResource WD.SuccessPrimaryButton}"/>
                                                <Button Content="开启闪烁" Margin="8,4,8,8" Click="ContextContent_Twink_Click" Style="{StaticResource WD.PrimaryButton}"/>
                                                <Border BorderBrush="{DynamicResource WD.BorderBrush}" BorderThickness="0,1" Margin="12,4,12,8">
                                                    <TextBlock Text="右键自定义面板" Margin="0,8" Foreground="#999" FontSize="11" HorizontalAlignment="Center"/>
                                                </Border>
                                            </StackPanel>
                                        </Border>
                                    </wd:NotifyIcon.ContextContent>
                                </wd:NotifyIcon>
                                <TextBlock Text="右键点击此演示图标将弹出自定义面板。" TextWrapping="Wrap" Foreground="{DynamicResource WD.TextSecondaryBrush}" />
                            </StackPanel>
                        </GroupBox>

                        <GroupBox Header="点击/双击事件">
                            <StackPanel wd:PanelHelper.Spacing="8">
                                <TextBlock Text="NotifyIcon 提供 Click 和 MouseDoubleClick 两个路由事件（左键单击触发 Click，双击触发 MouseDoubleClick）：" TextWrapping="Wrap" />
                                <Border Background="{DynamicResource WD.BackgroundBrush}" Padding="8" CornerRadius="4">
                                    <TextBlock FontFamily="Consolas" FontSize="11" TextWrapping="Wrap">
                                    &lt;wd:NotifyIcon Title="WPF开发者"&gt;&#10;    &lt;i:Interaction.Triggers&gt;&#10;        &lt;i:EventTrigger EventName="Click"&gt;&#10;            &lt;i:InvokeCommandAction Command="{Binding ClickCommand}"/&gt;&#10;        &lt;/i:EventTrigger&gt;&#10;        &lt;i:EventTrigger EventName="MouseDoubleClick"&gt;&#10;            &lt;i:InvokeCommandAction Command="{Binding DblClickCommand}"/&gt;&#10;        &lt;/i:EventTrigger&gt;&#10;    &lt;/i:Interaction.Triggers&gt;&#10;&lt;/wd:NotifyIcon&gt;
                                    </TextBlock>
                                </Border>
                                <wd:NotifyIcon x:Name="NotifyIconEvents" Title="WPF开发者 - 事件演示（左键点击任务栏图标查看效果）" Click="NotifyIcon_Click" MouseDoubleClick="NotifyIcon_MouseDoubleClick"/>
                                <StackPanel Orientation="Horizontal" wd:PanelHelper.Spacing="10">
                                    <TextBlock Text="单击次数: " VerticalAlignment="Center"/>
                                    <TextBlock x:Name="ClickCountText" Text="0" VerticalAlignment="Center" FontWeight="Bold"/>
                                    <TextBlock Text="    双击次数: " VerticalAlignment="Center"/>
                                    <TextBlock x:Name="DoubleClickCountText" Text="0" VerticalAlignment="Center" FontWeight="Bold"/>
                                </StackPanel>
                                <TextBlock Text="左键单击/双击任务栏中的演示图标，上方计数会实时更新。" TextWrapping="Wrap" Foreground="{DynamicResource WD.TextSecondaryBrush}" />
                            </StackPanel>
                        </GroupBox>
                    </StackPanel>
                </ScrollViewer>
            </TabItem>
            <TabItem Header="托盘消息">
                <StackPanel Margin="10" wd:PanelHelper.Spacing="10">
                    <TextBlock Text="调用 NotifyIcon.ShowBalloonTip(title, message, type) 发送气泡通知" TextWrapping="Wrap" />
                    <StackPanel Width="250" wd:PanelHelper.Spacing="6">
                        <TextBox
                            x:Name="MyTextBox"
                            wd:ElementHelper.CornerRadius="3"
                            wd:ElementHelper.IsClear="True"
                            wd:ElementHelper.Watermark="请输入消息" />
                        <Button
                            wd:ElementHelper.CornerRadius="3"
                            Click="BtnNotifyIconMessage_Click"
                            Content="发送托盘消息"
                            Style="{StaticResource WD.SuccessPrimaryButton}" />
                    </StackPanel>
                    <TextBlock Text="type 支持 Info / Warning / Error / None" TextWrapping="Wrap" Foreground="{DynamicResource WD.TextSecondaryBrush}" />
                </StackPanel>
            </TabItem>
            <TabItem Header="图标闪烁">
                <StackPanel Margin="10" wd:PanelHelper.Spacing="10">
                    <TextBlock Text="通过 IsTwink 属性控制图标闪烁（用于提醒用户注意）" TextWrapping="Wrap" />
                    <CheckBox
                        x:Name="TwinkCheckBox"
                        wd:ElementHelper.CornerRadius="3"
                        Checked="IsTwink_Checked"
                        Unchecked="UnIsTwink_Checked"
                        Content="开启托盘闪烁" />
                </StackPanel>
            </TabItem>
        </TabControl>
        <controls:CodeViewer.SourceCodes>
            <controls:SourceCodeModel CodeSource="/WPFDevelopers.SamplesCode;component/ExampleViews/NotifyIconExample.xaml" CodeType="Xaml" />
            <controls:SourceCodeModel CodeSource="/WPFDevelopers.SamplesCode;component/ExampleViews/NotifyIconExample.xaml.cs" CodeType="CSharp" />
        </controls:CodeViewer.SourceCodes>
    </controls:CodeViewer>
</UserControl>
