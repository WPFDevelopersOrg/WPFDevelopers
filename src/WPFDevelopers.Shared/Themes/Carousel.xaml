<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:controls="clr-namespace:WPFDevelopers.Controls"
    xmlns:helpers="clr-namespace:WPFDevelopers.Helpers"
    xmlns:resx="clr-namespace:WPFDevelopers">
    <ResourceDictionary.MergedDictionaries>
        <ResourceDictionary Source="Basic/ControlBasic.xaml" />
    </ResourceDictionary.MergedDictionaries>

    <Style x:Key="WD.CarouselDotStyle" TargetType="ContentControl">
        <Setter Property="Background" Value="{DynamicResource WD.RegularTextBrush}" />
        <Setter Property="Width" Value="20" />
        <Setter Property="Height" Value="30" />
        <Setter Property="Margin" Value="3,0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ContentControl">
                    <Border
                        x:Name="OuterBorder"
                        Width="{TemplateBinding Width}"
                        Height="{TemplateBinding Height}"
                        Background="Transparent">
                        <Border
                            x:Name="InnerDot"
                            Width="16"
                            Height="3"
                            VerticalAlignment="Stretch"
                            Background="{DynamicResource WD.RegularTextBrush}"
                            CornerRadius="1.5" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <DataTrigger Value="True">
                            <DataTrigger.Binding>
                                <MultiBinding Converter="{StaticResource WD.SelectedIndexToBoolConverter}">
                                    <Binding Path="(ItemsControl.AlternationIndex)" RelativeSource="{RelativeSource Mode=FindAncestor, AncestorType=ContentPresenter}" />
                                    <Binding Path="SelectedIndex" RelativeSource="{RelativeSource AncestorType=controls:CarouselBase}" />
                                </MultiBinding>
                            </DataTrigger.Binding>
                            <Setter TargetName="InnerDot" Property="Background" Value="{DynamicResource WD.PrimaryBrush}" />
                        </DataTrigger>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="InnerDot" Property="Background" Value="{DynamicResource WD.PrimaryBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style
        x:Key="WD.CardCarousel"
        BasedOn="{StaticResource WD.ControlBasicStyle}"
        TargetType="{x:Type controls:CardCarousel}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="ShowArrows" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:CardCarousel}">
                    <controls:WDBorder
                        Padding="{TemplateBinding Padding}"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{Binding Path=(helpers:ElementHelper.CornerRadius), RelativeSource={RelativeSource TemplatedParent}}"
                        SnapsToDevicePixels="True">
                        <controls:SmallPanel Background="{TemplateBinding Background}" Clip="{Binding RelativeSource={RelativeSource AncestorType=controls:WDBorder}, Path=ContentClip}">
                            <Viewbox>
                                <Canvas
                                    x:Name="PART_ContentDock"
                                    Width="900"
                                    Height="400" />
                            </Viewbox>
                            <Button
                                x:Name="PART_PrevButton"
                                Width="40"
                                Height="40"
                                Margin="12,0,0,0"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                helpers:ElementHelper.IsRound="True"
                                Style="{DynamicResource WD.NormalButton}"
                                ToolTip="{Binding [Previous], Source={x:Static resx:LanguageManager.Instance}}"
                                Visibility="{TemplateBinding ShowArrows,
                                                             Converter={StaticResource WD.Bool2VisibilityConverter}}">
                                <controls:PathIcon
                                    Width="16"
                                    Height="16"
                                    Kind="ChevronLeft" />
                            </Button>
                            <Button
                                x:Name="PART_NextButton"
                                Width="40"
                                Height="40"
                                Margin="0,0,12,0"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                helpers:ElementHelper.IsRound="True"
                                Style="{DynamicResource WD.NormalButton}"
                                ToolTip="{Binding [Next], Source={x:Static resx:LanguageManager.Instance}}"
                                Visibility="{TemplateBinding ShowArrows,
                                                             Converter={StaticResource WD.Bool2VisibilityConverter}}">
                                <controls:PathIcon
                                    Width="16"
                                    Height="16"
                                    Kind="ChevronRight" />
                            </Button>
                            <ItemsControl
                                x:Name="PART_Dots"
                                Margin="0,180,0,0"
                                HorizontalAlignment="Center"
                                AlternationCount="1000"
                                ItemsSource="{Binding DotsItems, RelativeSource={RelativeSource AncestorType=controls:CardCarousel}}"
                                Visibility="{TemplateBinding ShowDots,
                                                             Converter={StaticResource WD.Bool2VisibilityConverter}}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <ContentControl Style="{StaticResource WD.CarouselDotStyle}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </controls:SmallPanel>
                    </controls:WDBorder>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style
        x:Key="WD.FocusCarousel"
        BasedOn="{StaticResource WD.ControlBasicStyle}"
        TargetType="{x:Type controls:FocusCarousel}">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:FocusCarousel}">
                    <controls:SmallPanel Background="{TemplateBinding Background}">
                        <Canvas x:Name="PART_BackCanvas" />
                    </controls:SmallPanel>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style
        x:Key="WD.Carousel"
        BasedOn="{StaticResource WD.ControlBasicStyle}"
        TargetType="{x:Type controls:Carousel}">
        <Setter Property="ClipToBounds" Value="True" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type controls:Carousel}">
                    <controls:WDBorder
                        Padding="{TemplateBinding Padding}"
                        Background="{TemplateBinding Background}"
                        BorderBrush="{TemplateBinding BorderBrush}"
                        BorderThickness="{TemplateBinding BorderThickness}"
                        CornerRadius="{Binding Path=(helpers:ElementHelper.CornerRadius), RelativeSource={RelativeSource TemplatedParent}}"
                        SnapsToDevicePixels="True">
                        <controls:SmallPanel Background="{TemplateBinding Background}" Clip="{Binding RelativeSource={RelativeSource AncestorType=controls:WDBorder}, Path=ContentClip}">
                            <Border ClipToBounds="True">
                                <Canvas x:Name="PART_Content" />
                            </Border>
                            <Button
                                x:Name="PART_PrevButton"
                                Width="40"
                                Height="40"
                                Margin="12,0,0,0"
                                HorizontalAlignment="Left"
                                VerticalAlignment="Center"
                                helpers:ElementHelper.IsRound="True"
                                Style="{DynamicResource WD.NormalButton}"
                                ToolTip="{Binding [Previous], Source={x:Static resx:LanguageManager.Instance}}"
                                Visibility="{TemplateBinding ShowArrows,
                                                             Converter={StaticResource WD.Bool2VisibilityConverter}}">
                                <controls:PathIcon
                                    Width="16"
                                    Height="16"
                                    Kind="ChevronLeft" />
                            </Button>
                            <Button
                                x:Name="PART_NextButton"
                                Width="40"
                                Height="40"
                                Margin="0,0,12,0"
                                HorizontalAlignment="Right"
                                VerticalAlignment="Center"
                                helpers:ElementHelper.IsRound="True"
                                Style="{DynamicResource WD.NormalButton}"
                                ToolTip="{Binding [Next], Source={x:Static resx:LanguageManager.Instance}}"
                                Visibility="{TemplateBinding ShowArrows,
                                                             Converter={StaticResource WD.Bool2VisibilityConverter}}">
                                <controls:PathIcon
                                    Width="16"
                                    Height="16"
                                    Kind="ChevronRight" />
                            </Button>
                            <ItemsControl
                                x:Name="PART_Dots"
                                HorizontalAlignment="Center"
                                VerticalAlignment="Bottom"
                                AlternationCount="1000"
                                ItemsSource="{Binding DotsItems, RelativeSource={RelativeSource AncestorType=controls:Carousel}}"
                                Visibility="{TemplateBinding ShowDots,
                                                             Converter={StaticResource WD.Bool2VisibilityConverter}}">
                                <ItemsControl.ItemsPanel>
                                    <ItemsPanelTemplate>
                                        <StackPanel Orientation="Horizontal" />
                                    </ItemsPanelTemplate>
                                </ItemsControl.ItemsPanel>
                                <ItemsControl.ItemTemplate>
                                    <DataTemplate>
                                        <ContentControl Style="{StaticResource WD.CarouselDotStyle}" />
                                    </DataTemplate>
                                </ItemsControl.ItemTemplate>
                            </ItemsControl>
                        </controls:SmallPanel>
                    </controls:WDBorder>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>
    <Style BasedOn="{StaticResource WD.Carousel}" TargetType="{x:Type controls:Carousel}" />
    <Style BasedOn="{StaticResource WD.FocusCarousel}" TargetType="{x:Type controls:FocusCarousel}" />
    <Style BasedOn="{StaticResource WD.CardCarousel}" TargetType="{x:Type controls:CardCarousel}" />
</ResourceDictionary>